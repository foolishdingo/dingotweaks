@page
@model ARKERATEST1.Pages.ChatModel
@{
    ViewData["Title"] = "Chat Room";
}

<style>
    .chat-room {
        width: 100%;
        margin: 0;
        padding: 0;
    }

    .container-fluid {
        padding-left: 0;
        padding-right: 0;
    }

    .room-viewport {
        position: relative;
        width: 100%;
        height: calc(100vh - 320px);
        min-height: 400px;
        border-radius: 0;
        overflow: hidden;
    }

        .room-viewport img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }

    .avatar-group {
        position: absolute;
        bottom: 80px;
        left: 120px;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .speech-bubble {
        position: relative;
        background: white;
        border: 1px solid #000;
        border-radius: 8px;
        padding: 5px 16px;
        font-size: 13px;
        color: #000;
        max-width: 300px;
        margin-bottom: 8px;
        white-space: nowrap;
    }

        .speech-bubble::after {
            content: '';
            position: absolute;
            bottom: -8px;
            left: 50%;
            transform: translateX(-50%) rotate(45deg);
            width: 14px;
            height: 14px;
            background: white;
            border-right: 1px solid #000;
            border-bottom: 1px solid #000;
        }

    .room-avatar {
        text-align: center;
    }

        .room-avatar img {
            height: 130px;
            display: block;
            margin: 0 auto;
        }

        .room-avatar .avatar-name {
            font-size: 16px;
            font-weight: 600;
            color: #fda3a4;
            text-shadow: 0 0 5px #55002A;
            margin-top: 0px;
        }

    .chat-log-panel {
        background: var(--arkera-mid);
        padding: 5px;
    }

    .chat-log {
        background: var(--arkera-dark);
        border: 1px solid #2a2a4a;
        border-radius: 0;
        height: 80px;
        overflow-y: auto;
        padding: 5px 10px;
        font-size: 13px;
        line-height: 1.2;
    }

        .chat-log p {
            margin: 0;
            padding: 1px 0;
        }

        .chat-log .msg-time {
            color: #9f9f9f;
        }

        .chat-log .msg-user {
            color: #fda3a4;
            font-weight: 700;
        }

        .chat-log .msg-text {
            color: var(--arkera-text);
        }

    /* ── Fixed input bar ── */
    .chat-input-bar {
        position: fixed;
        bottom: 0;
        left: 0;
        width: 100%;
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 8px 16px;
        background: var(--arkera-mid);
        border-top: 1px solid #2a2a4a;
        z-index: 100;
        flex-wrap: wrap;
    }

    .autoscroll-label {
        display: flex;
        align-items: center;
        gap: 5px;
        font-size: 12px;
        color: var(--arkera-text);
        cursor: pointer;
        white-space: nowrap;
    }

    /* ── Bootstrap overrides ── */
    .btn-primary {
        height: 31px;
        padding: 0 12px;
        border-radius: 4px;
        border: 1px solid #5da8c3 !important;
        background-color: #1a3a4a !important;
        color: var(--arkera-text) !important;
        font-size: 12px;
        line-height: 31px;
        white-space: nowrap;
    }

        .btn-primary:hover {
            background-color: #5da8c3 !important;
            color: #000 !important;
            border-color: #5da8c3 !important;
        }

        .btn-primary.send-btn,
        .btn-primary.send-btn:hover,
        .btn-primary.send-btn:focus,
        .btn-primary.send-btn:active {
            background-color: var(--arkera-accent) !important;
            border-color: #b85a20 !important;
            color: white !important;
            font-weight: 600;
        }

            .btn-primary.send-btn:hover {
                background-color: #b85a20 !important;
            }

    .form-control,
    .form-control:focus {
        background-color: var(--arkera-dark) !important;
        border: 1px solid #2a2a4a !important;
        color: var(--arkera-text) !important;
        box-shadow: none !important;
        height: 31px;
    }

        .form-control::placeholder {
            color: #9f9f9f !important;
        }

    input.form-control {
        background-color: #0d0d1a !important;
        border: 1px solid #2a2a4a !important;
        color: #e8e8f0 !important;
        box-shadow: none !important;
    }

        input.form-control:focus {
            background-color: #0d0d1a !important;
            color: #e8e8f0 !important;
            box-shadow: none !important;
        }

    .chat-input {
        flex: 1;
        min-width: 200px;
        height: 31px;
        background-color: #0d0d1a;
        border: 1px solid #2a2a4a;
        border-radius: 4px;
        padding: 0 10px;
        color: #e8e8f0;
        font-size: 13px;
    }

        .chat-input::placeholder {
            color: #9f9f9f;
        }

    /* nuclear option for send button */
    button.btn.btn-primary.send-btn {
        background-color: #d4692a !important;
        border-color: #b85a20 !important;
        color: white !important;
        font-weight: 600;
    }

        button.btn.btn-primary.send-btn:hover {
            background-color: #b85a20 !important;
        }

    .send-btn {
        height: 31px;
        padding: 0 12px;
        border-radius: 4px;
        background-color: #d4692a;
        border: 1px solid #b85a20;
        color: white;
        font-weight: 600;
        font-size: 12px;
        cursor: pointer;
        white-space: nowrap;
    }

        .send-btn:hover {
            background-color: #b85a20;
        }
</style>

<div class="chat-room">

    <div class="room-viewport">
        <img class="room-bg" src="~/images/TSRoom.jpg" alt="Room background" />
        <div class="avatar-group">
            <div class="speech-bubble">hello i love chatting, yapping and spamming</div>
            <div class="room-avatar">
                <img src="~/Images/A1Lay.png" alt="Dingo avatar" />
                <div class="avatar-name">Dingo</div>
            </div>
        </div>
    </div>

    <div class="chat-log-panel">
        <div class="chat-log" id="chatLog">
            <p><span class="msg-time">[12:02:33]</span> <span class="msg-user">Fenriruser</span><span class="msg-text">: hello i love chatting, yapping and spamming</span></p>
            <p><span class="msg-time">[12:03:52]</span> <span class="msg-user">Fenriruser</span><span class="msg-text">: hello i love chatting, yapping and spamming</span></p>
            <p><span class="msg-time">[12:04:33]</span> <span class="msg-user">Fenriruser</span><span class="msg-text">: hello i love chatting, yapping and spamming</span></p>
            <p><span class="msg-time">[12:05:00]</span> <span class="msg-user">Fenriruser</span><span class="msg-text">: hello i love chatting, yapping and spamming</span></p>
            <p><span class="msg-time">[12:06:58]</span> <span class="msg-user">Fenriruser</span><span class="msg-text">: hello i love chatting, yapping and spamming</span></p>
            <p><span class="msg-time">[12:07:32]</span> <span class="msg-user">Fenriruser</span><span class="msg-text">: hello i love chatting, yapping and spamming</span></p>
        </div>

        <div class="w-100 d-flex gap-2 py-1 chat-input-bar">
            <input class="chat-input"
                   type="text"
                   placeholder="Type a message here...."
                   id="msgInput" />
            <button class="btn send-btn" onclick="sendMessage()">Send</button>
            <label class="autoscroll-label">
                <input type="checkbox" id="autoscroll" checked /> autoscroll
            </label>
            <button class="btn btn-primary">objects</button>
            <button class="btn btn-primary">avatars</button>
            <button class="btn btn-primary">settings</button>
            <button class="btn btn-primary">admin</button>
        </div>
    </div>

</div>

<script>
    function sendMessage() {
        var input = document.getElementById('msgInput');
        var log = document.getElementById('chatLog');
        var autoscroll = document.getElementById('autoscroll');

        if (input.value.trim() === '') return;

        document.querySelector('.speech-bubble').textContent = input.value;

        var now = new Date();
        var time = '[' + now.getHours().toString().padStart(2,'0') + ':'
                       + now.getMinutes().toString().padStart(2,'0') + ':'
                       + now.getSeconds().toString().padStart(2,'0') + ']';

        var p = document.createElement('p');
        p.innerHTML = '<span class="msg-time">' + time + '</span> '
                    + '<span class="msg-user">Dingo</span>'
                    + '<span class="msg-text">: ' + input.value + '</span>';
        log.appendChild(p);

        input.value = '';

        if (autoscroll.checked) log.scrollTop = log.scrollHeight;
    }

    document.getElementById('msgInput').addEventListener('keypress', function(e) {
        if (e.key === 'Enter') sendMessage();
    });
</script>